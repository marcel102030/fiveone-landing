# ── index.html — nunca cachear, sempre servir a versão mais recente
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# ── Assets com hash no nome (JS/CSS gerados pelo Vite) — cache longo e imutável
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*.png
  Cache-Control: public, max-age=31536000, immutable

/assets/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable

# ── Imagens do blog (sem hash, podem ser substituídas)
/blog/*.png
  Cache-Control: public, max-age=86400

/blog/*.jpg
  Cache-Control: public, max-age=86400

# ── PWA / service worker — nunca cachear
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/site.webmanifest
  Cache-Control: no-cache
